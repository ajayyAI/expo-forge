{
  "name": "expo-forge",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ajay/expo-forge.git"
  },
  "main": "expo-router/entry",
  "engines": {
    "node": ">=20.19.4"
  },
  "scripts": {
    "start": "expo start",
    "prebuild": "bunx expo prebuild",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "xcode": "xed -b ios",
    "doctor": "bunx expo-doctor@latest",
    "start:preview": "cross-env EXPO_PUBLIC_APP_ENV=preview bun run start",
    "prebuild:preview": "cross-env EXPO_PUBLIC_APP_ENV=preview STRICT_ENV_VALIDATION=1 bun run prebuild",
    "prebuild:development": "cross-env EXPO_PUBLIC_APP_ENV=development STRICT_ENV_VALIDATION=1 bun run prebuild",
    "android:preview": "cross-env EXPO_PUBLIC_APP_ENV=preview bun run android",
    "ios:preview": "cross-env EXPO_PUBLIC_APP_ENV=preview bun run ios",
    "start:production": "cross-env EXPO_PUBLIC_APP_ENV=production bun run start",
    "prebuild:production": "cross-env EXPO_PUBLIC_APP_ENV=production STRICT_ENV_VALIDATION=1 bun run prebuild",
    "android:production": "cross-env EXPO_PUBLIC_APP_ENV=production bun run android",
    "ios:production": "cross-env EXPO_PUBLIC_APP_ENV=production bun run ios",
    "build:development:ios": "eas build --profile development --platform ios",
    "build:development:android": "eas build --profile development --platform android",
    "build:preview:ios": "eas build --profile preview --platform ios",
    "build:preview:android": "eas build --profile preview --platform android",
    "build:production:ios": "eas build --profile production --platform ios",
    "build:production:android": "eas build --profile production --platform android",
    "prepare": "husky",
    "lint": "bunx ultracite check",
    "format": "bunx ultracite fix",
    "type-check": "tsc --noemit",
    "lint:translations": "bun scripts/check-translations.ts",
    "test": "jest",
    "check-all": "bun run lint && bun run type-check && bun run lint:translations && bun run test",
    "test:ci": "bun run test --coverage",
    "test:watch": "bun run test --watch",
    "install-maestro": "curl -Ls 'https://get.maestro.mobile.dev' | bash",
    "e2e-test": "maestro test .maestro/ -e APP_ID=com.expoforge.development"
  },
  "dependencies": {
    "@better-auth/expo": "1.6.11",
    "@convex-dev/better-auth": "0.12.2",
    "@convex-dev/rate-limiter": "^0.3.2",
    "@convex-dev/resend": "^0.2.4",
    "@expo-google-fonts/inter": "^0.4.2",
    "@expo/app-integrity": "^56.0.3",
    "@expo/metro-runtime": "~56.0.13",
    "@expo/ui": "~56.0.15",
    "@expo/vector-icons": "^15.0.2",
    "@gorhom/bottom-sheet": "^5.2.8",
    "@react-native-google-signin/google-signin": "^16.1.2",
    "@sentry/react-native": "~7.11.0",
    "@shopify/flash-list": "2.0.2",
    "@tanstack/react-form": "^1.27.7",
    "@tanstack/react-query": "^5.100.14",
    "app-icon-badge": "^0.1.2",
    "better-auth": "1.6.11",
    "cbor-x": "^1.6.4",
    "convex": "^1.39.1",
    "convex-helpers": "^0.1.118",
    "expo": "~56.0.8",
    "expo-apple-authentication": "~56.0.4",
    "expo-blur": "~56.0.3",
    "expo-build-properties": "~56.0.16",
    "expo-constants": "~56.0.16",
    "expo-dev-client": "~56.0.18",
    "expo-device": "~56.0.4",
    "expo-font": "~56.0.5",
    "expo-glass-effect": "~56.0.4",
    "expo-haptics": "~56.0.3",
    "expo-image": "~56.0.9",
    "expo-image-picker": "~56.0.15",
    "expo-insights": "~56.0.15",
    "expo-linking": "~56.0.13",
    "expo-local-authentication": "~56.0.4",
    "expo-localization": "~56.0.6",
    "expo-network": "~56.0.4",
    "expo-notifications": "~56.0.15",
    "expo-router": "~56.2.8",
    "expo-secure-store": "~56.0.4",
    "expo-splash-screen": "~56.0.10",
    "expo-store-review": "~56.0.3",
    "expo-symbols": "~56.0.5",
    "expo-updates": "~56.0.17",
    "heroui-native": "^1.0.4",
    "i18next": "^25.8.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-i18next": "^16.5.3",
    "react-native": "0.85.3",
    "react-native-edge-to-edge": "^1.7.0",
    "react-native-flash-message": "^0.4.2",
    "react-native-gesture-handler": "~2.31.1",
    "react-native-keyboard-controller": "1.21.6",
    "react-native-mmkv": "~4.1.1",
    "react-native-nitro-modules": "^0.33.2",
    "react-native-purchases": "^10.2.0",
    "react-native-purchases-ui": "^10.2.0",
    "react-native-reanimated": "4.3.1",
    "react-native-restart": "0.0.27",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-svg": "15.15.4",
    "react-native-web": "~0.21.2",
    "react-native-worklets": "0.8.3",
    "tailwind-merge": "^3.4.0",
    "tailwind-variants": "^3.2.2",
    "uniwind": "1.7.0",
    "zod": "^4.3.5",
    "zustand": "^5.0.10"
  },
  "devDependencies": {
    "@babel/core": "^7.28.6",
    "@biomejs/biome": "^2.3.4",
    "@commitlint/cli": "^20.3.1",
    "@commitlint/config-conventional": "^20.3.1",
    "@edge-runtime/jest-environment": "^4.0.0",
    "@edge-runtime/vm": "^5.0.0",
    "@expo/config": "^56.0.0",
    "@tailwindcss/cli": "^4.0.0",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^29.5.14",
    "@types/react": "~19.2.14",
    "babel-plugin-dynamic-import-node": "^2.3.3",
    "babel-plugin-module-resolver": "^5.0.2",
    "convex-test": "^0.0.53",
    "cross-env": "^10.1.0",
    "dotenv": "^17.2.3",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "jest-expo": "~56.0.4",
    "jest-junit": "^16.0.0",
    "lint-staged": "^16.2.7",
    "react-test-renderer": "19.2.3",
    "tailwindcss": "4.1.18",
    "tsx": "^4.21.0",
    "typescript": "~6.0.3",
    "ultracite": "^6.3.2"
  },
  "expo": {
    "doctor": {
      "reactNativeDirectoryCheck": {
        "listUnknownPackages": false,
        "exclude": [
          "react-native-restart"
        ]
      }
    },
    "install": {
      "exclude": [
        "react-native-worklets"
      ]
    }
  },
  "trustedDependencies": [
    "@parcel/watcher",
    "unrs-resolver"
  ]
}
