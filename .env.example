# Copy to `.env`. Leave blanks unless you are testing that feature.
# Never commit real secrets. Values with EXPO_PUBLIC_ are bundled into the app.

# -----------------------------------------------------------------------------
# 1. Fresh clone defaults
# -----------------------------------------------------------------------------

EXPO_PUBLIC_APP_ENV=development

# Example env values used by the sample env tests.
EXPO_PUBLIC_VAR_NUMBER=
EXPO_PUBLIC_VAR_BOOL=

# Build-time only. Not exposed to app code.
APP_BUILD_ONLY_VAR=

# -----------------------------------------------------------------------------
# 2. Optional client features
# -----------------------------------------------------------------------------

# External REST API base URL. Leave blank if you use only Convex or no API.
# EXPO_PUBLIC_API_URL=

# Universal links / app links host, for example:
# EXPO_PUBLIC_ASSOCIATED_DOMAIN=https://links.example.com
# EXPO_PUBLIC_ASSOCIATED_DOMAIN=

# Settings rows. Set only the rows you want shown.
# EXPO_PUBLIC_SUPPORT_EMAIL=
# EXPO_PUBLIC_GITHUB_URL=
# EXPO_PUBLIC_WEBSITE_URL=

# Auth behavior. Defaults are open app, no global login wall, no app lock.
# EXPO_PUBLIC_AUTH_REQUIRED=false
# EXPO_PUBLIC_BIOMETRIC_LOCK=false

# -----------------------------------------------------------------------------
# 3. Convex + Better Auth
# -----------------------------------------------------------------------------

# Optional. The app boots without Convex. Set both when testing auth/backend.
EXPO_PUBLIC_CONVEX_URL=
EXPO_PUBLIC_CONVEX_SITE_URL=

# Optional social sign-in buttons. Client ids are public.
# EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
# EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
# EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=
# EXPO_PUBLIC_APPLE_AUTH_ENABLED=false

# Email + password sign-in. Off by default — the template ships passwordless
# (email OTP + social). Set to "true" to surface the password and sign-up flows.
# EXPO_PUBLIC_PASSWORD_AUTH_ENABLED=false

# -----------------------------------------------------------------------------
# 4. Sentry / analytics
# -----------------------------------------------------------------------------

# Optional crash reporting. DSN is public.
# EXPO_PUBLIC_SENTRY_DSN=

# Optional Sentry source-map upload. Set SENTRY_AUTH_TOKEN only in EAS/CI secrets.
# SENTRY_ORG=
# SENTRY_PROJECT=
# SENTRY_AUTH_TOKEN=

# Optional PostHog adapter values if you wire a PostHog analytics adapter.
# EXPO_PUBLIC_POSTHOG_KEY=
# EXPO_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# -----------------------------------------------------------------------------
# 5. RevenueCat in-app purchases
# -----------------------------------------------------------------------------

# Optional. The app boots without it; the paywall stays hidden until the key for
# the running platform is set (see src/features/purchases/). These are RevenueCat
# *publishable* keys — safe to bundle in the app, unlike the secret server key.
# Find them under Project settings → API keys in the RevenueCat dashboard. Real
# purchases need a development build and are native-only (no web). Provision the
# "pro" entitlement, products, and offerings on the dashboard with the
# asc-revenuecat-catalog-sync skill.
# EXPO_PUBLIC_REVENUECAT_IOS_API_KEY=
# EXPO_PUBLIC_REVENUECAT_ANDROID_API_KEY=

# Optional. Overrides the default "pro" entitlement identifier.
# EXPO_PUBLIC_REVENUECAT_ENTITLEMENT_ID=

# -----------------------------------------------------------------------------
# 6. EAS build metadata
# -----------------------------------------------------------------------------

# Optional for local dev. Required when linking production EAS builds/updates.
# EAS_PROJECT_ID=
# EXPO_ACCOUNT_OWNER=

# Usually set by scripts/eas profiles. Leave blank for `bunx expo start`.
# STRICT_ENV_VALIDATION=

# -----------------------------------------------------------------------------
# 7. Convex deployment env
# -----------------------------------------------------------------------------
# These belong in Convex (`bunx convex env set ...`), not in the app bundle.
# Keeping names here is a reference for backend setup.

CONVEX_SITE_URL=
SITE_URL=
APP_NAME=
EMAIL_FROM=
REQUIRE_EMAIL_VERIFICATION=
RESEND_TEST_MODE=

# Google OAuth server credentials.
# GOOGLE_WEB_CLIENT_ID=
# GOOGLE_IOS_CLIENT_ID=
# GOOGLE_ANDROID_CLIENT_ID=
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# Apple Sign In server credentials.
# APPLE_CLIENT_ID=
# APPLE_CLIENT_SECRET=

# Apple App Attest / universal links backend values.
# APP_BUNDLE_ID=
# APPLE_TEAM_ID=
# APP_ATTEST_ENVIRONMENT=
# APP_ATTEST_ENFORCEMENT=

# Convex deploy key is secret. Set it in CI only.
# CONVEX_DEPLOY_KEY=
